---
const today = new Date();
---

<footer>
	<p class="insert-coin">★ INSERT COIN ★</p>
	<p class="copy">&copy; {today.getFullYear()} BOWEI — ALL RIGHTS RESERVED</p>
	<div class="social-links">
		<a href="https://github.com/Xu929-X1" target="_blank">
			<span class="sr-only">Bowei on GitHub</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 2.5em 1em 4em 1em;
		background: var(--bg-2);
		border-top: var(--px) solid var(--cyan);
		color: var(--dim);
		text-align: center;
	}
	.insert-coin {
		font-family: var(--font-pixel);
		font-size: 0.8rem;
		color: var(--yellow);
		text-shadow: 2px 2px 0 #000;
		animation: blink-coin 1s infinite steps(1);
		margin-bottom: 0.8em;
	}
	@keyframes blink-coin {
		50% { opacity: 0.15; }
	}
	.copy {
		font-family: var(--font-pixel);
		font-size: 0.55rem;
		color: var(--dim);
		line-height: 1.8;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1.2em;
		margin-top: 1.2em;
	}
	.social-links a {
		text-decoration: none;
		border: none;
		color: var(--purple);
	}
	.social-links a:hover {
		color: var(--cyan);
		background: none;
		transform: translateY(-3px);
	}
</style>
