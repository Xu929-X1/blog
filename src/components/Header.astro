---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
const base = import.meta.env.BASE_URL;
---

<header>
	<nav>
		<a class="logo" href={base}><span class="coin">●</span> {SITE_TITLE}</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/Xu929-X1" target="_blank">
				<span class="sr-only">Bowei on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0.6em 1em;
		background: var(--bg-2);
		border-bottom: var(--px) solid var(--magenta);
		box-shadow: 0 6px 0 #000;
		position: sticky;
		top: 0;
		z-index: 50;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5em;
		max-width: 960px;
		margin: 0 auto;
	}
	.logo {
		font-family: var(--font-pixel);
		font-size: 0.85rem;
		color: var(--yellow);
		text-decoration: none;
		border: none;
		text-shadow: 2px 2px 0 #000;
		padding: 0.4em 0;
	}
	.logo:hover {
		background: none;
		color: var(--cyan);
	}
	.coin {
		color: var(--yellow);
		animation: spin-coin 1.2s infinite steps(4);
		display: inline-block;
	}
	@keyframes spin-coin {
		0% { transform: scaleX(1); }
		50% { transform: scaleX(0.2); color: var(--magenta); }
		100% { transform: scaleX(1); }
	}
	.internal-links {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
	}
	/* arcade menu items */
	nav :global(.internal-links a) {
		font-family: var(--font-pixel);
		font-size: 0.62rem;
		color: var(--ink);
		padding: 0.6em 0.7em 0.6em 1.4em;
		position: relative;
		border: 2px solid transparent;
		text-decoration: none;
	}
	nav :global(.internal-links a::before) {
		content: '\25B6';
		position: absolute;
		left: 0.45em;
		color: var(--green);
		opacity: 0;
		transform: translateX(-4px);
		transition: opacity 0.1s steps(2), transform 0.1s steps(2);
	}
	nav :global(.internal-links a:hover),
	nav :global(.internal-links a.active) {
		color: var(--green);
		background: none;
		border-color: var(--green);
	}
	nav :global(.internal-links a:hover::before),
	nav :global(.internal-links a.active::before) {
		opacity: 1;
		transform: translateX(0);
		animation: blink 0.8s infinite steps(1);
	}
	@keyframes blink {
		50% { opacity: 0; }
	}
	.social-links,
	.social-links a {
		display: flex;
		border: none;
	}
	.social-links a {
		color: var(--purple);
		padding: 0;
	}
	.social-links a:hover {
		color: var(--cyan);
		background: none;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
