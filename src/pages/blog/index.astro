---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.screen-title {
				text-align: center;
				margin-bottom: 1.5em;
			}
			.screen-title p {
				font-family: var(--font-pixel);
				font-size: 0.6rem;
				color: var(--green);
				animation: blink 1s infinite steps(1);
			}
			@keyframes blink { 50% { opacity: 0; } }
			ul {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: 1.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li * {
				text-decoration: none;
				transition: transform 0.08s steps(2);
			}
			ul li img {
				width: 100%;
				margin: 0;
				border: none;
				border-bottom: var(--px) solid #000;
				box-shadow: none;
				aspect-ratio: 2 / 1;
				object-fit: cover;
			}
			ul li a {
				display: block;
				border: var(--px) solid #000;
				background: var(--panel);
				box-shadow: var(--shadow-hard);
			}
			ul li a:hover {
				transform: translate(-2px, -2px);
				box-shadow: 8px 8px 0 var(--magenta);
			}
			.title {
				font-family: var(--font-pixel);
				font-size: 0.85rem;
				margin: 0;
				padding: 0.9em 0.8em 0.6em;
				color: var(--yellow);
				line-height: 1.3;
			}
			.date {
				font-family: var(--font-pixel);
				font-size: 0.55rem;
				margin: 0;
				padding: 0 0.8em 1.2em;
				color: var(--cyan);
			}
			ul li a:hover .title { color: var(--green); }
			@media (max-width: 720px) {
				main { width: 100%; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="screen-title">
				<h1>STAGE SELECT</h1>
				<p>▼ CHOOSE YOUR POST ▼</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
