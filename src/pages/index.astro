---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="title-screen">
				<p class="kicker">PLAYER 1 START</p>
				<h1 class="arcade-title">BOWEI'S<br />BLOG</h1>
				<p class="tagline">A side-scrolling adventure through code, ideas &amp; pixels.</p>
				<a class="start-btn" href={`${base}/blog`}>▶ PRESS START</a>
				<p class="hi-score">HI-SCORE&nbsp;&nbsp;999999</p>
			</section>

			<section class="select">
				<h2>SELECT LEVEL</h2>
				<p class="howto">
					<span class="key">←</span><span class="key">→</span> MOVE &nbsp;·&nbsp;
					<span class="key">SPACE</span> JUMP &nbsp;·&nbsp; BONK A <span class="qmark">?</span> BLOCK TO GO
				</p>

				<div class="playfield" id="playfield" tabindex="0" aria-label="Mini platformer menu. Use arrow keys to move and space to jump into a block to navigate.">
					<div class="clouds"></div>

					<a class="qbox" href={`${base}/blog`} data-label="BLOG">
						<span class="q">?</span>
						<span class="qlabel">BLOG</span>
					</a>
					<a class="qbox" href={`${base}/about`} data-label="ABOUT">
						<span class="q">?</span>
						<span class="qlabel">ABOUT</span>
					</a>
					<a class="qbox" href="https://github.com/Xu929-X1" target="_blank" data-label="GITHUB">
						<span class="q">?</span>
						<span class="qlabel">GITHUB</span>
					</a>

					<div class="hero" id="hero">
						<svg class="sprite" viewBox="0 0 12 15" shape-rendering="crispEdges" aria-hidden="true">
							<!-- antenna -->
							<rect class="bulb" x="5" y="0" width="1" height="1" fill="#ff2e88" />
							<rect x="5" y="1" width="1" height="1" fill="#0b0a1e" />
							<!-- head -->
							<rect x="3" y="2" width="6" height="1" fill="#21e6ff" />
							<rect x="2" y="3" width="8" height="6" fill="#21e6ff" />
							<rect x="3" y="3" width="6" height="1" fill="#8af6ff" />
							<!-- visor -->
							<rect x="2" y="5" width="8" height="2" fill="#0b0a1e" />
							<rect class="eye" x="4" y="5" width="1" height="2" fill="#39ff14" />
							<rect class="eye" x="7" y="5" width="1" height="2" fill="#39ff14" />
							<!-- cheeks + mouth -->
							<rect x="2" y="7" width="1" height="1" fill="#ff2e88" />
							<rect x="9" y="7" width="1" height="1" fill="#ff2e88" />
							<rect x="5" y="8" width="2" height="1" fill="#0b0a1e" />
							<!-- arms -->
							<rect x="1" y="8" width="1" height="3" fill="#21e6ff" />
							<rect x="10" y="8" width="1" height="3" fill="#21e6ff" />
							<rect x="1" y="10" width="1" height="1" fill="#ff2e88" />
							<rect x="10" y="10" width="1" height="1" fill="#ff2e88" />
							<!-- torso -->
							<rect x="3" y="9" width="6" height="2" fill="#21e6ff" />
							<rect x="5" y="9" width="2" height="1" fill="#ffd23f" />
							<!-- legs + feet -->
							<rect x="4" y="11" width="1" height="3" fill="#0b0a1e" />
							<rect x="7" y="11" width="1" height="3" fill="#0b0a1e" />
							<rect x="3" y="13" width="2" height="1" fill="#ff2e88" />
							<rect x="7" y="13" width="2" height="1" fill="#ff2e88" />
						</svg>
					</div>
					<div class="ground"></div>
				</div>
				<p class="tap-hint">On touch? Just tap a block.</p>
			</section>
		</main>
		<Footer />

		<style>
	.title-screen {
		text-align: center;
		padding: 2em 0 3em;
	}
	.kicker {
		font-family: var(--font-pixel);
		font-size: 0.7rem;
		color: var(--green);
		animation: blink 1s infinite steps(1);
		margin-bottom: 1.5em;
	}
	@keyframes blink { 50% { opacity: 0; } }
	.arcade-title {
		font-size: clamp(2rem, 9vw, 4.5rem);
		line-height: 1.15;
		color: var(--yellow);
		letter-spacing: 2px;
		text-shadow:
			4px 4px 0 var(--magenta),
			8px 8px 0 #000,
			0 0 24px rgba(255, 210, 63, 0.4);
		margin-bottom: 0.6em;
	}
	.tagline {
		max-width: 28ch;
		margin: 0 auto 2em;
		color: var(--ink);
		font-size: 1.2rem;
	}
	.start-btn {
		display: inline-block;
		font-family: var(--font-pixel);
		font-size: 0.9rem;
		color: #000;
		background: var(--cyan);
		border: var(--px) solid #000;
		box-shadow: var(--shadow-hard);
		padding: 0.9em 1.4em;
		text-decoration: none;
		animation: pulse 0.9s infinite steps(2);
	}
	.start-btn:hover {
		background: var(--magenta);
		color: #fff;
		transform: translate(3px, 3px);
		box-shadow: 3px 3px 0 #000;
		animation: none;
	}
	@keyframes pulse { 50% { opacity: 0.6; } }
	.hi-score {
		font-family: var(--font-pixel);
		font-size: 0.6rem;
		color: var(--magenta);
		margin-top: 2.5em;
	}

	.select { margin-top: 1em; }
	.select h2 { text-align: center; margin-bottom: 0.8em; }
	.howto {
		text-align: center;
		font-family: var(--font-pixel);
		font-size: 0.5rem;
		line-height: 2;
		color: var(--dim);
		margin-bottom: 1.2em;
	}
	.howto .key {
		display: inline-block;
		padding: 2px 5px;
		margin: 0 1px;
		color: var(--ink);
		background: #000;
		border: 2px solid var(--cyan);
	}
	.howto .qmark { color: var(--yellow); }

	/* ---- playfield ---- */
	.playfield {
		position: relative;
		height: 320px;
		overflow: hidden;
		background:
			linear-gradient(180deg, #1a1450 0%, #2a1a66 60%, #3a2480 100%);
		border: var(--px) solid #000;
		box-shadow: var(--shadow-hard);
		outline: none;
		image-rendering: pixelated;
	}
	.playfield:focus-visible { border-color: var(--green); }
	.clouds {
		position: absolute;
		inset: 0;
		background-image:
			radial-gradient(circle at 18% 24%, rgba(255,255,255,0.18) 0 18px, transparent 19px),
			radial-gradient(circle at 70% 16%, rgba(255,255,255,0.14) 0 22px, transparent 23px),
			radial-gradient(circle at 88% 40%, rgba(255,255,255,0.10) 0 14px, transparent 15px);
		animation: drift 18s linear infinite alternate;
	}
	@keyframes drift { to { transform: translateX(-24px); } }

	.ground {
		position: absolute;
		left: 0; right: 0; bottom: 0;
		height: 40px;
		background:
			repeating-linear-gradient(90deg, #b5651d 0 14px, #8a4a14 14px 16px),
			#a85c1a;
		border-top: var(--px) solid #000;
	}

	.qbox {
		position: absolute;
		top: 96px;
		width: 56px;
		height: 56px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		background: var(--yellow);
		border: var(--px) solid #000;
		box-shadow: inset -4px -4px 0 #c79a14, inset 4px 4px 0 #ffe98a;
		text-decoration: none;
		cursor: pointer;
	}
	.qbox:nth-child(2) { left: 16%; }
	.qbox:nth-child(3) { left: 46%; top: 70px; }
	.qbox:nth-child(4) { left: 76%; }
	.qbox .q {
		font-family: var(--font-pixel);
		font-size: 1.1rem;
		color: #000;
		animation: qpulse 0.8s infinite steps(2);
	}
	@keyframes qpulse { 50% { opacity: 0.55; } }
	.qbox .qlabel {
		font-family: var(--font-pixel);
		font-size: 0.32rem;
		color: #000;
		margin-top: 2px;
	}
	.qbox:hover { background: #fff04a; }
	.qbox.hit {
		background: #7a5a12;
		box-shadow: inset -4px -4px 0 #5a4210, inset 4px 4px 0 #9a7a1a;
		animation: bonk 0.25s steps(3);
	}
	.qbox.hit .q { color: var(--magenta); animation: none; }
	@keyframes bonk {
		0% { transform: translateY(0); }
		40% { transform: translateY(-14px); }
		100% { transform: translateY(0); }
	}
	/* coin pop */
	.coin {
		position: absolute;
		width: 16px; height: 16px;
		background: var(--yellow);
		border: 2px solid #000;
		border-radius: 50%;
		pointer-events: none;
		animation: coinpop 0.5s steps(5) forwards;
		z-index: 5;
	}
	@keyframes coinpop {
		0% { transform: translateY(0) scale(1); opacity: 1; }
		100% { transform: translateY(-70px) scale(1.4); opacity: 0; }
	}

	.hero {
		position: absolute;
		left: 24px;
		bottom: 40px;
		width: 34px;
		height: 40px;
		z-index: 4;
		will-change: transform, left;
		filter: drop-shadow(2px 3px 0 rgba(0, 0, 0, 0.55));
	}
	.hero .sprite {
		width: 100%;
		height: 100%;
		display: block;
		animation: bob 0.85s infinite ease-in-out;
		transform-origin: center bottom;
	}
	.hero.face-left { transform: scaleX(-1); }
	.hero .bulb { animation: bulb 0.7s infinite steps(2); }
	.hero .eye { animation: eyeglow 1.5s infinite ease-in-out; }
	@keyframes bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-1px); }
	}
	@keyframes bulb { 50% { opacity: 0.25; } }
	@keyframes eyeglow { 50% { opacity: 0.45; } }
	@media (prefers-reduced-motion: reduce) {
		.hero .sprite, .hero .bulb, .hero .eye { animation: none; }
	}

	.tap-hint {
		text-align: center;
		font-family: var(--font-pixel);
		font-size: 0.42rem;
		color: var(--dim);
		margin-top: 0.8em;
	}

	@media (max-width: 720px) {
		.playfield { height: 260px; }
		.qbox { width: 48px; height: 48px; }
	}
	@media (prefers-reduced-motion: reduce) {
		.clouds, .qbox .q { animation: none; }
	}
</style>

<script>
	const field = document.getElementById('playfield');
	const hero = document.getElementById('hero');
	if (field && hero) {
		const boxes = Array.from(field.querySelectorAll('.qbox'));

		// physics state (px, relative to field)
		const GROUND = 40;          // ground height
		const W = () => field.clientWidth;
		let x = 24;
		let vx = 0;
		let vy = 0;
		let onGround = true;
		const SPEED = 3.4;
		const GRAV = 0.9;
		const JUMP = 15;
		const heroW = 34, heroH = 40;

		const keys: Record<string, boolean> = {};
		const isMove = (k: string) =>
			['arrowleft', 'arrowright', 'a', 'd', ' ', 'arrowup', 'w', 'spacebar'].includes(k);

		function jump() {
			if (onGround) { vy = JUMP; onGround = false; }
		}

		const focused = () => document.activeElement === field;
		window.addEventListener('keydown', (e) => {
			if (!focused()) return;
			const k = e.key.toLowerCase();
			if (isMove(k)) {
				e.preventDefault();
				keys[k] = true;
				if (k === ' ' || k === 'arrowup' || k === 'w' || k === 'spacebar') jump();
			}
		});
		window.addEventListener('keyup', (e) => { keys[e.key.toLowerCase()] = false; });

		// focus field on click so keyboard works (no auto-focus -> avoids page jump)
		field.addEventListener('mousedown', () => field.focus());

		let navigating = false;
		function hitBox(box: Element) {
			if (navigating || box.classList.contains('hit')) return;
			box.classList.add('hit');
			vy = -6; // bounce hero down
			// coin
			const coin = document.createElement('div');
			coin.className = 'coin';
			const b = box as HTMLElement;
			coin.style.left = b.offsetLeft + b.offsetWidth / 2 - 8 + 'px';
			coin.style.top = b.offsetTop - 4 + 'px';
			field.appendChild(coin);
			navigating = true;
			const href = (box as HTMLAnchorElement).href;
			const target = (box as HTMLAnchorElement).target;
			setTimeout(() => {
				if (target === '_blank') { window.open(href, '_blank'); navigating = false; box.classList.remove('hit'); }
				else window.location.href = href;
			}, 480);
		}

		function loop() {
			// horizontal
			vx = 0;
			if (keys['arrowleft'] || keys['a']) vx = -SPEED;
			if (keys['arrowright'] || keys['d']) vx = SPEED;
			if (vx < 0) hero.classList.add('face-left');
			else if (vx > 0) hero.classList.remove('face-left');
			x += vx;
			x = Math.max(2, Math.min(W() - heroW - 2, x));

			// vertical
			vy -= GRAV;
			let y = parseFloat(hero.style.bottom || String(GROUND));
			y += vy;
			if (y <= GROUND) { y = GROUND; vy = 0; onGround = true; }

			// box collision (hero head hitting box underside while rising)
			if (vy > 0) {
				const heroLeft = x, heroRight = x + heroW;
				const heroTop = field.clientHeight - (y + heroH); // top offset from field top
				for (const box of boxes) {
					const bx = (box as HTMLElement).offsetLeft;
					const bw = (box as HTMLElement).offsetWidth;
					const bBottom = (box as HTMLElement).offsetTop + (box as HTMLElement).offsetHeight;
					const overlapX = heroRight > bx + 6 && heroLeft < bx + bw - 6;
					if (overlapX && heroTop <= bBottom && heroTop >= bBottom - 18) {
						hitBox(box);
					}
				}
			}

			hero.style.left = x + 'px';
			hero.style.bottom = y + 'px';
			requestAnimationFrame(loop);
		}
		hero.style.bottom = GROUND + 'px';
		requestAnimationFrame(loop);
	}
</script>
	</body>
</html>
